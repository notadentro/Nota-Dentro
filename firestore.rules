rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueia qualquer acesso por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Coleção users
    match /users/{userId} {
      // O usuário pode ler apenas o próprio documento
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // O usuário pode criar o próprio documento (apenas no momento do cadastro)
      // e pode atualizar campos como stats.xp, progress e achievements.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
